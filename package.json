{
  "name": "paddock",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "F1 stats dashboard built with @jjordy/rogue.",
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "onlyBuiltDependencies": [],
    "patchedDependencies": {
      "@jjordy/rogue": "patches/@jjordy__rogue.patch"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsx scripts/ssg.ts",
    "build:client": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "sync-data": "tsx scripts/sync-data.ts"
  },
  "dependencies": {
    "@jjordy/rogue": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "linkedom": "^0.18.12",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vite": "^5.4.0"
  }
}
